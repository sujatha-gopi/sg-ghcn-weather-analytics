cat > .gitignore << 'EOF'
# Environment variables - NEVER commit these
.env
*.env

# GCP credentials
*.json
service-account*.json

# Python
__pycache__/
*.pyc
*.pyo
.venv/
venv/
*.egg-info/

# dbt
dbt/target/
dbt/dbt_packages/
dbt/logs/

# Terraform
terraform/.terraform/
terraform/*.tfstate
terraform/*.tfstate.backup
terraform/.terraform.lock.hcl

# Data files (can be large)
*.csv
*.csv.gz
*.parquet

# OS
.DS_Store
Thumbs.db
EOF